{
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "bunx --bun vite dev",
    "build": "bunx --bun vite build",
    "preview": "bunx --bun vite preview",
    "prepare": "panda codegen && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "clean": "rm -rf .svelte-kit build node_modules",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "codegen": "panda codegen"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/schibsted-grotesk": "^5.2.8",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/schibsted-grotesk": "^5.2.8",
    "@iconify/json": "^2.2.428",
    "@iconify/types": "^2.0.0",
    "@iconify/utils": "^3.1.0",
    "@logtape/logtape": "^2.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tiptap/core": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "@tiptap/static-renderer": "^3.26.0",
    "@xevion/satori-html": "^0.4.1",
    "blurhash": "^2.0.5",
    "cookie": "^1.1.1",
    "overlayscrollbars": "^2.13.0",
    "overlayscrollbars-svelte": "^0.5.5",
    "posthog-js": "^1.323.0",
    "posthog-node": "^5.21.0",
    "sanitize-html": "^2.17.4",
    "satori": "^0.18.3",
    "svelte-dnd-action": "^0.9.69",
    "svelte-sonner": "^1.1.1",
    "svelte-tiptap": "^3.0.1",
    "true-myth": "^9.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@fontsource/inter": "^5.2.8",
    "@pandacss/dev": "^1.8.2",
    "@sveltejs/kit": "^2.49.5",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.0.9",
    "@types/sanitize-html": "^2.16.1",
    "@xevion/tempo": "^0.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.0.0",
    "html-minifier-terser": "^7.2.0",
    "prettier": "^3.8.0",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.46.4",
    "svelte-adapter-bun": "npm:@xevion/svelte-adapter-bun@^1.0.1",
    "svelte-check": "^4.3.5",
    "typescript-eslint": "^8.53.0",
    "unplugin-icons": "^23.0.1",
    "vite": "^7.3.1"
  }
}
