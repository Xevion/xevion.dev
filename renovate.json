{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": false,
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "description": "Group Rust dependency updates",
      "matchManagers": ["cargo"],
      "groupName": "rust dependencies"
    },
    {
      "description": "Group npm/bun dependency updates",
      "matchManagers": ["npm"],
      "groupName": "frontend dependencies"
    },
    {
      "description": "Update the peer-coupled SvelteKit/Vite toolchain together, including majors.",
      "matchManagers": ["npm"],
      "matchPackageNames": ["vite", "svelte", "@sveltejs/**"],
      "groupName": "sveltekit/vite toolchain",
      "separateMajorMinor": false
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions",
      "pinDigests": true
    },
    {
      "description": "Group Docker image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker images"
    },
    {
      "description": "Auto-merge patch updates after CI passes",
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
