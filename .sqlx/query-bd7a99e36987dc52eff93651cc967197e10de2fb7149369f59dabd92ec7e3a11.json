{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT p.id, p.slug, p.name, p.project_type, p.accent_color\n        FROM project_relations r\n        JOIN projects p ON p.id = r.related_project_id\n        WHERE r.project_id = $1 AND p.status != 'hidden'\n        ORDER BY r.position ASC\n        ",
