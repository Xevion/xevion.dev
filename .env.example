# Database (auto-populated by `just db`)
DATABASE_URL=postgresql://xevion:dev@localhost:5432/xevion

# Admin credentials (used by `xevion-server seed`)
ADMIN_PASSWORD=password

# Cloudflare R2 (media storage + OG image cache)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=xevion-media
VITE_OG_R2_BASE_URL=https://media.xevion.dev

# Public origin baked into prerendered pages (error pages, /pgp) at build time,
# for og:url + canonical. Defaults to https://xevion.dev in code when unset.
VITE_SITE_ORIGIN=https://xevion.dev

# GitHub (activity sync background job)
GITHUB_TOKEN=

# PostHog analytics (optional, proxied via Cloudflare Workers)
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=

# CLI API client (optional, for `xevion` commands)
API_BASE_URL=https://xevion.dev

# Server ports (FRONTEND_PORT defaults to PORT+1 if unset)
PORT=10237
FRONTEND_PORT=10238

# Logging
LOG_JSON=false            # true = structured JSON, false = pretty colored output
LOG_LEVEL=info            # debug | info | warn | error
# RUST_LOG=trace,api=debug  # Advanced: full tracing filter syntax (overrides LOG_LEVEL)

# sqlx compile-time query checking (set to true to skip live DB requirement)
SQLX_OFFLINE=true

# Public hosts (per-domain SSR origin + host-keyed ISR cache)
# Allowlist of public hostnames served by this deploy. The ISR cache keys by
# validated host, so each domain gets its own SSR variant; an untrusted
# X-Forwarded-Host falls back to CANONICAL_HOST. Leave PUBLIC_HOSTS unset in dev
# to trust the incoming Host as-is (e.g. localhost:10237).
# PUBLIC_HOSTS=xevion.dev,walters.to
# CANONICAL_HOST=xevion.dev   # Fallback host; defaults to the first PUBLIC_HOSTS entry

# ISR cache (stale-while-revalidate page cache for SSR responses)
ISR_CACHE_ENABLED=true
ISR_CACHE_MAX_ENTRIES=1000  # Max cached pages (multiplied by the number of public hosts)
ISR_CACHE_FRESH_SEC=60      # Seconds a response is considered fresh
ISR_CACHE_STALE_SEC=300     # Seconds before eviction (serves stale in this window)

# Tarpit (slow-drip infinite response for malicious scanner paths)
TARPIT_ENABLED=true
TARPIT_DELAY_MIN_MS=100   # Min delay between chunks
TARPIT_DELAY_MAX_MS=500   # Max delay between chunks
TARPIT_CHUNK_MIN=64       # Min chunk size in bytes
TARPIT_CHUNK_MAX=1024     # Max chunk size in bytes
TARPIT_MAX_GLOBAL=1000    # Max concurrent tarpit connections globally
TARPIT_MAX_PER_IP=100     # Max concurrent tarpit connections per IP
