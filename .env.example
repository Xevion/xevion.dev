# Database (auto-populated by `just db`)
DATABASE_URL=postgresql://xevion:dev@localhost:5432/xevion

# Admin credentials (used by `xevion seed`)
ADMIN_PASSWORD=password

# Cloudflare R2 (media storage + OG image cache)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=xevion-media
VITE_OG_R2_BASE_URL=https://media.xevion.dev

# GitHub (activity sync background job)
GITHUB_TOKEN=

# PostHog analytics (optional, proxied via Cloudflare Workers)
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=

# CLI API client (optional, for `xevion api` commands)
API_BASE_URL=https://xevion.dev
